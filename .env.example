# .env
SECRET_KEY=replace-this-with-a-secure-secret-generated-with-secrets
DEBUG=true
SITE_NAME=Your Name
BASE_URL=http://localhost:8000
CONTACT_WEBHOOK_URL=https://discord.com/api/webhooks/...
TELEMETRY_ENABLED=true
TELEMETRY_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
TELEMETRY_EXPORTER_OTLP_INSECURE=true
TELEMETRY_LOGS_ENABLED=true
FRONTEND_TELEMETRY_ENABLED=true
FRONTEND_TELEMETRY_OTLP_ENDPOINT=
FRONTEND_TELEMETRY_SAMPLE_RATIO=1.0
# The app also accepts standard OTEL_* aliases when it reads `.env`.
# For `opentelemetry-instrument`, export OTEL_* in the shell or process env;
# values that exist only in `.env` are not loaded by the OTel distro.
# OTEL_SERVICE_NAME=portfolio-backend
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
DEFAULT_RATE_LIMIT=60/minute
RATE_LIMIT=10/minute
TRUST_FORWARDED_IP_HEADERS=false
TRUSTED_HOSTS=localhost,127.0.0.1
CORS_ALLOW_ORIGINS=
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,X-Request-ID
CORS_ALLOW_CREDENTIALS=false
MAX_REQUEST_BODY_BYTES=1048576
CONTACT_MAX_BODY_BYTES=65536

# Production profile (docker-compose.prod.yml)
# DEV_TELEMETRY_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4317
# PROD_BASE_URL=https://example.com
# PROD_TRUSTED_HOSTS=example.com,www.example.com
# PROD_CORS_ALLOW_ORIGINS=https://example.com
# PROD_FRONTEND_TELEMETRY_ENABLED=true
# PROD_TELEMETRY_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4317
# PROD_FRONTEND_TELEMETRY_OTLP_ENDPOINT=
# PROD_PUBLIC_HTTP_PORT=80
