{#import "@ui/card.jinja" as Card #}
{#import "@ui/tag.jinja" as Tag #}
{#import "@ui/section-link.jinja" as SectionLink #}
{#import "@ui/empty-state.jinja" as EmptyState #}
{#import "@ui/card-heading.jinja" as CardHeading #}
{#def latest_posts=() #}

<section class="flex flex-col min-h-0">
    <a
        href="/blog"
        class="group block mb-3"
        data-analytics-event="click"
        data-analytics-id="home-blog-heading"
        data-analytics-label="blog"
        data-analytics-target="/blog"
    >
        <h2 class="text-lg font-semibold text-white flex items-center gap-2 group-hover:text-blue-400 transition-colors">
            Blog
        </h2>
    </a>

    <div class="space-y-3 flex-1 overflow-hidden">
        {% for post in latest_posts %}
        <Card href={{ '/blog/posts/' ~ post.slug }} padding="sm">
            <div class="flex flex-col gap-1">
                <CardHeading title={{ post.title }} date={{ post.date }} featured={{ post.featured }} title_class="text-sm text-white font-medium group-hover:text-blue-400 transition-colors" />
                <p class="text-xs text-gray-500 line-clamp-1">{{ post.description }}</p>
                {% if post.tags %}
                <div class="mt-1 flex flex-wrap gap-1.5">
                    {% for tag in post.tags[:3] %}
                    <Tag text={{ tag }} />
                    {% endfor %}
                </div>
                {% endif %}
            </div>
        </Card>
        {% else %}
        <EmptyState message="No blog posts yet." />
        {% endfor %}
    </div>

    <div class="mt-3">
        <SectionLink
            href="/blog/posts"
            label="View all posts"
            data-analytics-event="click"
            data-analytics-id="section-link-view-all-posts"
            data-analytics-label="View all posts"
            data-analytics-target="/blog/posts"
        />
    </div>
</section>
