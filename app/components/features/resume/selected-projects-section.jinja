{#import "@ui/section.jinja" as Section #}
{#import "@ui/section-link.jinja" as SectionLink #}
{#import "@ui/tag.jinja" as Tag #}
{#import "@ui/card-heading.jinja" as CardHeading #}
{#def projects=() #}

<Section title="Selected Projects" heading_id="selected-projects" visible={{ projects | length > 0 }} class_name="gap-y-5">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <p class="max-w-2xl text-sm text-gray-400">
            A few projects that reflect how I structure backend systems, content pipelines, and operational defaults.
        </p>
        <SectionLink href="/projects" label="View all projects" class_name="resume-section-link" />
    </div>

    <div class="resume-projects-grid">
        {% for project in projects %}
        {% set chips = project.tech_stack if project.tech_stack else project.tags %}
        <a
            href="/projects/{{ project.slug }}"
            class="resume-project-link group"
        >
            <article class="space-y-3">
                <CardHeading title={{ project.title }} date={{ project.date }} featured={{ project.featured }} title_class="resume-project-title text-base font-semibold text-white transition-colors group-hover:text-blue-400" featured_class="text-green-500" label="Project" />

                {% if project.description %}
                <p class="line-clamp-2 text-sm leading-relaxed text-gray-400">
                    {{ project.description }}
                </p>
                {% endif %}

                {% if chips %}
                <div class="flex flex-wrap gap-1.5">
                    {% for chip in chips[:2] %}
                    <Tag text={{ chip }} variant="outline" size="sm" />
                    {% endfor %}
                </div>
                {% endif %}
            </article>
        </a>
        {% endfor %}
    </div>
</Section>
