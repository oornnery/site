{#import "@layouts/public.jinja" as PublicLayout #}
{#import "@ui/tag.jinja" as Tag #}
{#import "@ui/button.jinja" as Button #}
{#import "@ui/icon.jinja" as Icon #}
{#import "@ui/breadcrumb.jinja" as Breadcrumb #}
{#import "@ui/row.jinja" as Row #}
{#import "@ui/content-shell.jinja" as ContentShell #}
{#import "@ui/meta-info.jinja" as MetaInfo #}
{#def seo, project, current_path="/projects" #}

<PublicLayout seo={{ seo }} current_path={{ current_path }}>
    {% set breadcrumb_items = (
        {"label": "Home", "href": "/"},
        {"label": "Projects", "href": "/projects"},
        {"label": project.title, "current": true},
    ) %}

    <div class="space-y-4 sm:space-y-6">
        <Breadcrumb items={{ breadcrumb_items }} class_name="text-sm text-gray-500 -mt-2 sm:-mt-3 fade-in flex items-center" />

        <article class="space-y-8">
            <header>
                <div class="max-w-3xl">
                    <MetaInfo>
                        {% if project.date %}
                        <span>{{ project.date.year }}</span>
                        {% endif %}
                        {% if project.featured %}
                        <span>&bull;</span>
                        <span class="text-green-500">★ Featured</span>
                        {% endif %}
                    </MetaInfo>

                    <h1 class="text-4xl font-bold text-white mb-4 sm:mb-5 leading-tight">{{ project.title }}</h1>

                    {% if project.description %}
                    <p class="text-xl text-gray-400">{{ project.description }}</p>
                    {% endif %}

                    {% set chips = project.tech_stack if project.tech_stack else project.tags %}
                    {% if chips %}
                    <Row wrap={{ true }} gap="2" class_name="mt-4">
                        {% for tech in chips %}
                        <Tag text={{ tech }} />
                        {% endfor %}
                    </Row>
                    {% endif %}

                    <Row wrap={{ true }} gap="4" class_name="mt-6">
                        {% if project.live_url and ('example.' not in project.live_url) %}
                        <Button href={{ project.live_url }} variant="primary" size="default" target="_blank" rel="noopener noreferrer" class="min-w-[146px]">
                            <Icon name="external-link" size="sm" />
                            <span>Live Demo</span>
                        </Button>
                        {% endif %}
                        {% if project.github_url %}
                        <Button href={{ project.github_url }} size="default" target="_blank" rel="noopener noreferrer" class="min-w-[146px]">
                            <Icon name="github" size="sm" />
                            <span>Source Code</span>
                        </Button>
                        {% endif %}
                    </Row>
                </div>
            </header>

            <ContentShell content_class="prose">
                {{ project.content_html | safe }}
            </ContentShell>
        </article>
    </div>
</PublicLayout>
