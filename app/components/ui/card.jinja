{#def href="", variant="default", padding="default", hoverable=True, clickable=False #}

{% set variant_map = {
    "default": "bg-gray-900/50 border border-gray-800",
    "elevated": "bg-gray-900 shadow-lg shadow-black/20",
    "outlined": "bg-transparent border-2 border-gray-700",
    "ghost": "bg-gray-800/30",
    "glass": "bg-gray-900/30 backdrop-blur-md border border-gray-700/50",
    "gradient": "bg-gray-900/50 border border-gray-800"
} %}
{% set pad_map = {"none": "", "sm": "p-3 sm:p-4", "default": "p-4 sm:p-6", "lg": "p-6 sm:p-8"} %}
{% set hover = "hover:border-gray-600 hover:bg-gray-800/60" if hoverable else "" %}
{% set cls = "rounded-lg transition-all duration-200 " ~ variant_map[variant] ~ " " ~ pad_map[padding] ~ " " ~ hover %}

{% if href %}
<a href="{{ href }}" class="block group {{ cls }}" data-analytics-event="click" data-analytics-id="card-link" data-analytics-target="{{ href }}" {{ attrs.render() }}>
    {{ content }}
</a>
{% else %}
<div class="{{ cls }}" {{ attrs.render() }}>
    {{ content }}
</div>
{% endif %}
