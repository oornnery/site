{#def cols="2", gap="8", class_name="" #}

{% set col_classes = {
    "2": "grid grid-cols-1 md:grid-cols-2",
    "3": "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3",
    "4": "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4"
} %}
{% set gaps = {
    "4": "gap-4 sm:gap-6",
    "6": "gap-6 sm:gap-8",
    "8": "gap-8 sm:gap-12"
} %}
{% set cls = (col_classes.get(cols, "grid grid-cols-1 md:grid-cols-" ~ cols) ~ " " ~ gaps.get(gap, "gap-" ~ gap) ~ " " ~ class_name).strip() %}

<div class="{{ cls }}" {{ attrs.render() }}>
    {{ content }}
</div>
