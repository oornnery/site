{#def current_path="" #}

<nav class="navbar fixed top-0 left-0 right-0 z-50 bg-black/90 backdrop-blur-md border-b border-gray-800/50" data-navbar>
    <div class="max-w-4xl mx-auto flex flex-wrap items-center justify-between px-4 sm:px-6 py-3 sm:py-4">
        <a href="/" class="text-base sm:text-lg font-medium text-white tracking-tight hover:text-blue-400 transition-colors" data-analytics-event="click" data-analytics-id="nav-logo" data-analytics-label="logo">
            {{ site_name }}
        </a>

        <button type="button" class="navbar-toggle inline-flex items-center p-2.5 justify-center text-gray-400 rounded-lg md:hidden hover:bg-gray-800/50 hover:text-blue-400 focus:outline-none focus:ring-2 focus:ring-gray-600" aria-expanded="false" data-nav-toggle data-analytics-event="click" data-analytics-id="nav-menu-toggle" data-analytics-label="menu toggle">
            <span class="sr-only">Open main menu</span>
            <svg class="w-5 h-5" data-nav-icon-open xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14" aria-hidden="true">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
            </svg>
            <svg class="hidden w-5 h-5" data-nav-icon-close xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>

        <div class="hidden w-full md:!block md:w-auto" data-nav-menu>
            <ul class="flex flex-col mt-4 md:mt-0 md:flex-row md:space-x-1 lg:space-x-2 font-medium text-sm rounded-lg md:border-0 border border-gray-800 bg-black/95 md:bg-transparent p-4 md:p-0">
                {% for link in nav_links %}
                <li>
                    <a href="{{ link.href }}" class="block px-3 py-2 rounded-lg {{ 'text-white bg-gray-800/50' if current_path == link.href else 'text-gray-400 hover:text-blue-400 hover:bg-gray-800/30' }} transition-all" data-nav-link data-analytics-event="click" data-analytics-id="nav-{{ link.label | lower }}" data-analytics-label="{{ link.label }}">
                        {{ link.label }}
                    </a>
                </li>
                {% endfor %}
            </ul>
        </div>
    </div>
</nav>
