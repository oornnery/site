{#import "@ui/tag.jinja" as Tag #}
{#import "@features/blog/post-card.jinja" as PostCard #}
{#import "@ui/empty-state.jinja" as EmptyState #}
{#def tags=(), posts=(), selected_tag="" #}

<div id="tag-posts">
    <div class="flex flex-wrap gap-2 mb-6">
        <Tag
            href="/blog/tags"
            text="All"
            variant={{ "accent" if selected_tag == "" else "outline" }}
            hx-get="/blog/tags"
            hx-target="#tag-posts"
            hx-swap="outerHTML"
            hx-push-url="true"
        />
        {% for tag in tags %}
        <Tag
            href={{ "/blog/tags/" ~ (tag.name | urlencode) }}
            text={{ tag.name ~ " (" ~ tag.count ~ ")" }}
            variant={{ "accent" if selected_tag and selected_tag | lower == tag.name | lower else "outline" }}
            hx-get={{ "/blog/tags/" ~ (tag.name | urlencode) }}
            hx-target="#tag-posts"
            hx-swap="outerHTML"
            hx-push-url="true"
        />
        {% endfor %}
    </div>

    <div class="space-y-3 sm:space-y-4">
        {% for post in posts %}
        <PostCard post={{ post }} compact={{ true }} />
        {% else %}
        <EmptyState message="No posts found for this tag." />
        {% endfor %}
    </div>
</div>
