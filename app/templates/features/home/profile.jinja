{#import "@ui/nav/social.jinja" as SocialLinks #}
{#import "@ui/nav/section.jinja" as SectionLink #}
{#def profile_name, site_name, profile_role, profile_location, profile_summary, social_links #}

<div class="flex-1 text-center lg:text-left">
    <h1 class="text-2xl sm:text-3xl font-bold text-foreground mb-0">{{ profile_name or site_name }}</h1>
    {% if profile_role %}
    <p class="text-sm sm:text-base text-foreground/60 font-mono mb-1">
        {{ profile_role }}
    </p>
    {% endif %}
    {% if profile_location %}
    <p class="text-xs sm:text-sm text-foreground/50 font-mono mb-1.5">
        <a
            class="hover:underline hover:text-accent transition-colors"
            href="https://www.google.com/maps/search/{{ profile_location | urlencode }}"
            target="_blank"
            rel="noopener noreferrer"
            data-telemetry-event="outbound_click"
            data-telemetry-id="profile-location"
            data-telemetry-label="{{ profile_location }}"
            data-telemetry-target="https://www.google.com/maps/search/{{ profile_location | urlencode }}"
        >
            {{ profile_location }}
        </a>
    </p>
    {% endif %}
    <p class="text-xs sm:text-sm text-foreground/50 mb-4 max-w-xl">
        {{ profile_summary }}
    </p>

    <SocialLinks
        links={{ social_links }}
        variant="icons_inline"
        container_class="flex flex-wrap justify-center lg:justify-start gap-2 mb-3"
    />

    <SectionLink href="/about" label="View full resume" data-telemetry-event="click" data-telemetry-id="section-link-view-full-resume" data-telemetry-label="View full resume" data-telemetry-target="/about" />
</div>
