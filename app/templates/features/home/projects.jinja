{#import "@ui/card/card.jinja" as Card #}
{#import "@ui/tag.jinja" as Tag #}
{#import "@ui/nav/section.jinja" as SectionLink #}
{#import "@ui/layout/row.jinja" as Row #}
{#import "@ui/feedback/empty.jinja" as EmptyState #}
{#import "@ui/card/heading.jinja" as CardHeading #}
{#def featured=() #}

<section class="flex flex-col min-h-0">
    <a
        href="/projects"
        class="group block mb-3"
        data-analytics-event="click"
        data-analytics-id="home-projects-heading"
        data-analytics-label="projects"
        data-analytics-target="/projects"
    >
        <h2 class="text-lg font-semibold heading-hover flex items-center gap-2">
            Projects
        </h2>
    </a>

    <div class="space-y-3 flex-1 overflow-hidden">
        {% for project in featured %}
        <Card href={{ '/projects/' ~ project.slug }} padding="sm">
            <div class="flex flex-col gap-1">
                <CardHeading title={{ project.title }} date={{ project.date }} featured={{ project.featured }} title_class="text-sm text-foreground font-medium group-hover:text-accent transition-colors" featured_class="text-accent" />
                <p class="text-xs text-foreground/50 line-clamp-1">{{ project.description }}</p>
                <Row wrap={{ true }} gap="1.5" class_name="mt-1">
                    {% for tech in (project.tech_stack if project.tech_stack else project.tags)[:3] %}
                    <Tag text={{ tech }} variant="outline" />
                    {% endfor %}
                </Row>
            </div>
        </Card>
        {% else %}
        <EmptyState message="No projects yet." />
        {% endfor %}
    </div>

    <div class="mt-3">
        <SectionLink href="/projects" label="View all projects" data-analytics-event="click" data-analytics-id="section-link-view-all-projects" data-analytics-label="View all projects" data-analytics-target="/projects" />
    </div>
</section>
