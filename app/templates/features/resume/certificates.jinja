{#import "@ui/layout/section.jinja" as Section #}
{#import "@features/resume/entry.jinja" as EntryHeader #}
{#def items #}

<Section title="Certificates" heading_id="certificates" visible={{ items | length > 0 }} class_name="gap-y-6">
    <div class="resume-list">
        {% for item in items %}
        <article class="resume-certificate-item">
            <EntryHeader title={{ item.name }} subtitle={{ item.issuer }} date_text={{ item.date }} />
            {% if item.credential_id %}
            <p class="mt-1 font-mono text-[11px] text-foreground/50">ID: {{ item.credential_id }}</p>
            {% endif %}
            {% if item.details_html %}
            <div class="resume-richtext mt-3 text-sm text-foreground/60 leading-relaxed">
                {{ item.details_html | safe }}
            </div>
            {% endif %}
        </article>
        {% endfor %}
    </div>
</Section>
