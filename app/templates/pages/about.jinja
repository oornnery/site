{#import "@layouts/public.jinja" as PublicLayout #}
{#import "@ui/nav/breadcrumb.jinja" as Breadcrumb #}
{#import "@ui/content/shell.jinja" as ContentShell #}
{#import "@features/resume/header.jinja" as ProfileHeader #}
{#import "@features/resume/about.jinja" as AboutSection #}
{#import "@features/resume/experience.jinja" as ExperienceSection #}
{#import "@features/resume/education.jinja" as EducationSection #}
{#import "@features/resume/certificates.jinja" as CertificatesSection #}
{#import "@features/resume/skills.jinja" as SkillsSection #}
{#def seo, meta, hero_html="", about_html="", work_experience=(), education=(), certificates=(), skill_groups=(), current_path="/about" #}

<PublicLayout seo={{ seo }} current_path={{ current_path }}>
    {% set breadcrumb_items = (
        {"label": "Home", "href": "/"},
        {"label": "About", "current": true},
    ) %}

    <div class="space-y-8 sm:space-y-10" aria-label="Resume Content" id="resume-content">
        <div class="space-y-3 sm:space-y-4">
            <Breadcrumb items={{ breadcrumb_items }} />
            <div class="resume-intro-offset">
                <ProfileHeader meta={{ meta }} hero_html={{ hero_html }} profile_name={{ profile_name }} site_name={{ site_name }} social_links={{ social_links }} />
            </div>
        </div>

        <ContentShell max_width="max-w-4xl" content_class="resume-sections-stack">
            <AboutSection content_html={{ about_html }} />
            <ExperienceSection items={{ work_experience }} />
            <EducationSection items={{ education }} />
            <CertificatesSection items={{ certificates }} />
            <SkillsSection skill_groups={{ skill_groups }} />
        </ContentShell>
    </div>
</PublicLayout>
