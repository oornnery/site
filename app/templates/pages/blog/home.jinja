{#import "@layouts/public.jinja" as PublicLayout #}
{#import "@ui/nav/breadcrumb.jinja" as Breadcrumb #}
{#import "@ui/content/header.jinja" as PageHeader #}
{#import "@ui/layout/stack.jinja" as Stack #}
{#import "@ui/tag.jinja" as Tag #}
{#import "@ui/nav/section.jinja" as SectionLink #}
{#import "@ui/feedback/empty.jinja" as EmptyState #}
{#import "@features/blog/card.jinja" as PostCard #}
{#def seo, featured_posts=(), recent_posts=(), tags=(), current_path="/blog" #}

<PublicLayout seo={{ seo }} current_path={{ current_path }}>
    {% set breadcrumb_items = (
        {"label": "Home", "href": "/"},
        {"label": "Blog", "current": true},
    ) %}

    <Stack gap="6" class_name="sm:space-y-8">
        <Stack gap="4" class_name="sm:space-y-6">
            <Breadcrumb items={{ breadcrumb_items }} />

            <div class="flex flex-col gap-4 sm:gap-5 lg:flex-row lg:items-start lg:justify-between">
                <PageHeader
                    title="Blog"
                    subtitle="Notes on backend engineering, architecture tradeoffs, and production operations."
                    class="flex-1 lg:max-w-3xl"
                />
            </div>
        </Stack>

        <Stack gap="4" class_name="sm:space-y-5">
            {% if featured_posts %}
            {% set featured_total = featured_posts | length %}
            <div class="space-y-4" x-data="carousel()" @mouseenter="stopAutoplay()" @mouseleave="startAutoplay()" @focusin="stopAutoplay()" @focusout="startAutoplay()">
                <div class="flex items-center justify-between gap-3">
                    <h2 class="text-xl sm:text-2xl font-bold text-foreground">Featured Posts</h2>
                    {% if featured_total > 1 %}
                    <div class="flex items-center gap-2">
                        <button
                            type="button"
                            class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-accent/15 text-foreground/70 hover:text-accent hover:border-accent/40 transition-colors"
                            aria-label="Previous featured post"
                            data-carousel-prev
                            data-analytics-event="click"
                            data-analytics-id="blog-home-featured-prev"
                            data-analytics-label="Previous featured post"
                        >
                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </button>
                        <button
                            type="button"
                            class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-accent/15 text-foreground/70 hover:text-accent hover:border-accent/40 transition-colors"
                            aria-label="Next featured post"
                            data-carousel-next
                            data-analytics-event="click"
                            data-analytics-id="blog-home-featured-next"
                            data-analytics-label="Next featured post"
                        >
                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </button>
                    </div>
                    {% endif %}
                </div>

                <div class="featured-carousel-viewport" data-carousel-viewport>
                    <div class="featured-carousel-track" data-carousel-track>
                        {% for post in featured_posts %}
                        <div
                            data-slide
                            class="featured-carousel-slide"
                            aria-hidden="{{ 'false' if loop.first else 'true' }}"
                        >
                            <PostCard post={{ post }} />
                        </div>
                        {% endfor %}
                    </div>
                </div>

                {% if featured_total > 1 %}
                <div class="flex items-center justify-between gap-3">
                    <p class="text-xs text-foreground/50">
                        <span x-text="current + 1">1</span>/<span>{{ featured_total }}</span>
                    </p>
                    <div class="flex items-center gap-2" aria-label="Featured posts slide indicators">
                        {% for post in featured_posts %}
                        <button
                            type="button"
                            class="featured-carousel-dot"
                            aria-label="Go to featured post {{ loop.index }}"
                            data-carousel-dot="{{ loop.index0 }}"
                        ></button>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}
            </div>
            {% else %}
            <h2 class="text-xl sm:text-2xl font-bold text-foreground">Featured Posts</h2>
            <EmptyState message="No featured posts yet." />
            {% endif %}
        </Stack>

        <Stack gap="4" class_name="sm:space-y-5">
            <div class="flex items-center justify-between gap-3">
                <h2 class="text-xl sm:text-2xl font-bold text-foreground">Latest Posts</h2>
                <SectionLink href="/blog/posts" label="View all posts" />
            </div>
            {% if recent_posts %}
            <Stack gap="3" class_name="sm:space-y-4">
                {% for post in recent_posts %}
                <PostCard post={{ post }} dense={{ true }} />
                {% endfor %}
            </Stack>
            {% else %}
            <EmptyState message="No recent posts yet." />
            {% endif %}
        </Stack>

        <Stack gap="3">
            <div class="flex items-center justify-between gap-3">
                <h2 class="text-xl sm:text-2xl font-bold text-foreground">Tags</h2>
                <SectionLink href="/blog/tags" label="View all tags" />
            </div>
            {% if tags %}
            <div class="flex flex-wrap gap-2">
                {% for tag in tags %}
                <Tag
                    href={{ "/blog/tags/" ~ (tag.name | urlencode) }}
                    text={{ tag.name ~ " (" ~ tag.count ~ ")" }}
                    variant="outline"
                />
                {% endfor %}
            </div>
            {% else %}
            <p class="text-sm text-foreground/50">No tags available.</p>
            {% endif %}
        </Stack>
    </Stack>
</PublicLayout>
