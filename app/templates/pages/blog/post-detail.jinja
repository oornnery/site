{#import "@layouts/public.jinja" as PublicLayout #}
{#import "@ui/nav/breadcrumb.jinja" as Breadcrumb #}
{#import "@ui/tag.jinja" as Tag #}
{#import "@ui/layout/row.jinja" as Row #}
{#import "@ui/content-shell.jinja" as ContentShell #}
{#import "@ui/meta-info.jinja" as MetaInfo #}
{#import "@ui/card/card.jinja" as Card #}
{#import "@features/blog/github-comments.jinja" as GithubComments #}
{#def seo, post, previous_post=None, next_post=None, read_time_minutes=1, current_path="/blog" #}

<PublicLayout seo={{ seo }} current_path={{ current_path }}>
    {% set comment_source_label = "Gist" if post.gist_id else "GitHub" %}
    {% set breadcrumb_items = (
        {"label": "Home", "href": "/"},
        {"label": "Blog", "href": "/blog"},
        {"label": post.title, "current": true},
    ) %}

    <div class="reading-progress" data-reading-progress aria-hidden="true">
        <div class="reading-progress__bar" data-reading-progress-bar></div>
    </div>

    <div class="space-y-8 sm:space-y-10">
        <div class="space-y-4 sm:space-y-6">
            <Breadcrumb items={{ breadcrumb_items }} class_name="text-sm text-foreground/50 -mt-2 sm:-mt-3 fade-in flex items-center" />

            <article class="space-y-8">
                <header>
                    <div class="max-w-3xl">
                        <MetaInfo>
                            {% if post.date %}
                            <span>{{ post.date.strftime("%B %d, %Y") }}</span>
                            {% endif %}
                            {% if post.author %}
                            <span>&bull;</span>
                            <span>{{ post.author }}</span>
                            {% endif %}
                            <span>&bull;</span>
                            <span>{{ read_time_minutes }} min read</span>
                            {% if post.featured %}
                            <span>&bull;</span>
                            <span class="text-accent">Featured</span>
                            {% endif %}
                        </MetaInfo>

                        <h1 class="text-4xl font-bold text-foreground mb-4 sm:mb-5 leading-tight">{{ post.title }}</h1>

                        {% if post.description %}
                        <p class="text-xl text-foreground/60">{{ post.description }}</p>
                        {% endif %}

                        {% if post.tags %}
                        <Row wrap={{ true }} gap="2" class_name="mt-4">
                            {% for tag in post.tags %}
                            <Tag href={{ "/blog/tags/" ~ (tag | urlencode) }} text={{ tag }} variant="outline" />
                            {% endfor %}
                        </Row>
                        {% endif %}
                    </div>
                </header>

                <ContentShell content_class="prose">
                    {{ post.content_html | safe }}
                </ContentShell>
            </article>
        </div>

        <div class="max-w-3xl">
            <GithubComments
                discussion_url={{ post.discussion_url }}
                post_title={{ post.title }}
                comments={{ post.comments }}
                comment_source_label={{ comment_source_label }}
                show_cta={{ true }}
            />
        </div>

        {% if previous_post or next_post %}
        <section class="max-w-3xl section-divider-spacing border-t border-border/50">
            <div class="flex items-center justify-between mb-5">
                <h2 class="text-xl sm:text-2xl font-bold text-foreground">Continue Reading</h2>
                <a href="/blog/posts" class="text-sm link-hover">View all posts &rarr;</a>
            </div>
            <nav class="grid grid-cols-1 sm:grid-cols-2 gap-3" aria-label="Post navigation">
                {% if previous_post %}
                <Card href={{ '/blog/posts/' ~ previous_post.slug }} padding="sm">
                    <div class="space-y-1.5">
                        <span class="text-xs text-foreground/50">&larr; Previous</span>
                        <p class="text-sm font-semibold text-foreground group-hover:text-accent transition-colors line-clamp-1">{{ previous_post.title }}</p>
                        {% if previous_post.description %}
                        <p class="text-xs text-foreground/50 leading-relaxed line-clamp-1">{{ previous_post.description }}</p>
                        {% endif %}
                    </div>
                </Card>
                {% else %}
                <div></div>
                {% endif %}
                {% if next_post %}
                <Card href={{ '/blog/posts/' ~ next_post.slug }} padding="sm">
                    <div class="space-y-1.5">
                        <span class="text-xs text-foreground/50 block text-right">Next &rarr;</span>
                        <p class="text-sm font-semibold text-foreground group-hover:text-accent transition-colors line-clamp-1">{{ next_post.title }}</p>
                        {% if next_post.description %}
                        <p class="text-xs text-foreground/50 leading-relaxed line-clamp-1">{{ next_post.description }}</p>
                        {% endif %}
                    </div>
                </Card>
                {% else %}
                <div></div>
                {% endif %}
            </nav>
        </section>
        {% endif %}
    </div>
</PublicLayout>
