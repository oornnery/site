{#import "@layouts/public.jinja" as PublicLayout #}
{#import "@ui/nav/breadcrumb.jinja" as Breadcrumb #}
{#import "@ui/content/header.jinja" as PageHeader #}
{#import "@ui/layout/stack.jinja" as Stack #}
{#import "@ui/feedback/empty.jinja" as EmptyState #}
{#import "@ui/nav/pagination.jinja" as Pagination #}
{#import "@features/blog/card.jinja" as PostCard #}
{#def seo, posts=(), page=1, total_pages=1, current_path="/blog" #}

<PublicLayout seo={{ seo }} current_path={{ current_path }}>
    {% set breadcrumb_items = (
        {"label": "Home", "href": "/"},
        {"label": "Blog", "href": "/blog"},
        {"label": "Posts", "current": true},
    ) %}

    <Stack gap="6" class_name="sm:space-y-8">
        <Stack gap="4" class_name="sm:space-y-6">
            <Breadcrumb items={{ breadcrumb_items }} />

            <PageHeader
                title="All Posts"
                subtitle="Every published article."
            />
        </Stack>

        <Stack gap="3" class_name="sm:space-y-4">
            {% for post in posts %}
            <PostCard post={{ post }} tight={{ true }} />
            {% else %}
            <EmptyState message="No posts published yet." />
            {% endfor %}
        </Stack>

        <Pagination page={{ page }} total_pages={{ total_pages }} base_url="/blog/posts?" />
    </Stack>
</PublicLayout>
