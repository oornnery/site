{#import "@layouts/public.jinja" as PublicLayout #}
{#import "@ui/nav/breadcrumb.jinja" as Breadcrumb #}
{#import "@ui/page-header.jinja" as PageHeader #}
{#import "@ui/tag.jinja" as Tag #}
{#import "@ui/layout/stack.jinja" as Stack #}
{#import "@ui/empty-state.jinja" as EmptyState #}
{#import "@features/blog/post-card.jinja" as PostCard #}
{#def seo, tags=(), posts=(), selected_tag="", current_path="/blog" #}

<PublicLayout seo={{ seo }} current_path={{ current_path }}>
    {% if selected_tag %}
    {% set breadcrumb_items = (
        {"label": "Home", "href": "/"},
        {"label": "Blog", "href": "/blog"},
        {"label": "Tags", "href": "/blog/tags"},
        {"label": selected_tag, "current": true},
    ) %}
    {% else %}
    {% set breadcrumb_items = (
        {"label": "Home", "href": "/"},
        {"label": "Blog", "href": "/blog"},
        {"label": "Tags", "current": true},
    ) %}
    {% endif %}

    <Stack gap="6" class_name="sm:space-y-8">
        <Stack gap="4" class_name="sm:space-y-6">
            <Breadcrumb items={{ breadcrumb_items }} />

            <PageHeader
                title={{ ("Tag: " ~ selected_tag) if selected_tag else "Tags" }}
                subtitle="Browse posts by topic."
            />
        </Stack>

        <div class="flex flex-wrap gap-2">
            <Tag
                href="/blog/tags"
                text="All"
                variant={{ "accent" if selected_tag == "" else "outline" }}
            />
            {% for tag in tags %}
            <Tag
                href={{ "/blog/tags/" ~ (tag.name | urlencode) }}
                text={{ tag.name ~ " (" ~ tag.count ~ ")" }}
                variant={{ "accent" if selected_tag and selected_tag | lower == tag.name | lower else "outline" }}
            />
            {% endfor %}
        </div>

        <Stack gap="3" class_name="sm:space-y-4">
            {% for post in posts %}
            <PostCard post={{ post }} compact={{ true }} />
            {% else %}
            <EmptyState message="No posts found for this tag." />
            {% endfor %}
        </Stack>
    </Stack>
</PublicLayout>
