{#import "@layouts/public.jinja" as PublicLayout #}
{#import "@features/contact/fragment.jinja" as ContactFormSection #}
{#import "@ui/nav/social.jinja" as SocialLinks #}
{#import "@ui/nav/breadcrumb.jinja" as Breadcrumb #}
{#import "@ui/content/header.jinja" as PageHeader #}
{#import "@ui/layout/stack.jinja" as Stack #}
{#import "@ui/layout/grid.jinja" as Grid #}
{#def seo, csrf_token, success="", errors={}, form_data={}, current_path="/contact" #}

<PublicLayout seo={{ seo }} current_path={{ current_path }}>
    {% set breadcrumb_items = (
        {"label": "Home", "href": "/"},
        {"label": "Contact", "current": true},
    ) %}

    <Stack gap="6" class_name="sm:space-y-8">
        <Stack gap="4" class_name="sm:space-y-6">
            <Breadcrumb items={{ breadcrumb_items }} />
            <PageHeader title="Contact" subtitle="Get in touch with me." />
        </Stack>

        <Grid cols="2" gap="8">
            <section>
                <h2 class="text-lg font-medium text-foreground mb-4">Connect</h2>
                <SocialLinks links={{ social_links }} />
            </section>

            <ContactFormSection
                csrf_token={{ csrf_token }}
                success={{ success }}
                errors={{ errors }}
                form_data={{ form_data }}
            />
        </Grid>
    </Stack>
</PublicLayout>
