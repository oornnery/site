{#import "@ui/icon.jinja" as Icon #}
{#import "@ui/nav/social.jinja" as SocialLinks #}
{#def current_path="" #}

<footer class="w-full py-3 sm:py-4 border-t border-border/50">
    <div class="flex flex-wrap items-center justify-between text-sm text-foreground/50">
        <span>&copy; <span data-current-year>2026</span> {{ site_name }}</span>
        <div class="flex flex-wrap items-center gap-4">
            {% if social_links %}
            <SocialLinks
                links={{ social_links }}
                variant="labels_inline"
                container_class="flex flex-wrap items-center gap-4"
                link_class="link-hover inline-flex items-center gap-1.5"
                icon_size="sm"
            />
            {% endif %}
            {% if current_path and current_path.startswith("/blog") %}
            <a
                href="/blog/feed.xml"
                class="link-hover inline-flex items-center gap-1.5"
                aria-label="RSS"
                data-analytics-event="click"
                data-analytics-id="footer-rss"
                data-analytics-label="RSS"
                data-analytics-target="/blog/feed.xml"
            >
                <Icon name="rss" size="sm" />
                <span>RSS</span>
            </a>
            {% endif %}
        </div>
    </div>
</footer>
