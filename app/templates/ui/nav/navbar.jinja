{#def current_path="" #}

<nav
    class="navbar fixed top-0 left-0 right-0 z-50 bg-background/90 backdrop-blur-md border-b border-border/50"
    x-data="navbar()"
    @click.outside="close()"
    @keydown.escape.window="close()"
>
    <div class="max-w-4xl mx-auto flex flex-wrap items-center justify-between px-4 sm:px-6 py-3 sm:py-4">
        <a href="/" class="text-base sm:text-lg font-medium text-foreground tracking-tight hover:text-accent transition-colors" data-telemetry-event="click" data-telemetry-id="nav-logo" data-telemetry-label="logo">
            {{ site_name }}
        </a>

        <button
            type="button"
            class="navbar-toggle inline-flex items-center p-2.5 justify-center text-foreground/60 rounded-lg md:hidden hover:bg-surface-2/50 hover:text-accent focus:outline-none focus:ring-2 focus:ring-border-hover"
            :aria-expanded="ariaExpanded"
            @click="toggle()"
            data-telemetry-event="click"
            data-telemetry-id="nav-menu-toggle"
            data-telemetry-label="menu toggle"
        >
            <span class="sr-only">Open main menu</span>
            {# hamburger icon — hidden when open #}
            <svg :class="{ 'hidden': open }" class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14" aria-hidden="true">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
            </svg>
            {# close icon — shown when open #}
            <svg :class="{ 'hidden': !open }" class="hidden w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>

        <div :class="{ 'hidden': !open }" class="hidden w-full md:!block md:w-auto">
            <ul class="flex flex-col mt-4 md:mt-0 md:flex-row md:space-x-1 lg:space-x-2 font-medium text-sm rounded-lg md:border-0 border border-border bg-background/95 md:bg-transparent p-4 md:p-0 items-center">
                {% for link in nav_links %}
                <li>
                    <a href="{{ link.href }}" class="block px-3 py-2 rounded-lg {{ 'text-foreground bg-surface-2/50' if current_path == link.href else 'text-foreground/60 hover:text-accent hover:bg-surface-2/30' }} transition-all" data-telemetry-event="click" data-telemetry-id="nav-{{ link.label | lower }}" data-telemetry-label="{{ link.label }}">
                        {{ link.label }}
                    </a>
                </li>
                {% endfor %}

                <li class="flex items-center gap-1" x-data="palette()" @click.outside="closeMenu()" @keydown.escape.window="closeMenu()">
                    {# Dark/Light toggle #}
                    <button
                        type="button"
                        class="inline-flex items-center justify-center p-2 rounded-lg text-foreground/60 hover:text-accent hover:bg-surface-2/30 transition-all"
                        :aria-label="modeLabel"
                        @click="toggleMode()"
                    >
                        {# sun icon — shown in dark mode (click to go light) #}
                        <svg :class="{ 'hidden': isLight }" class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path></svg>
                        {# moon icon — shown in light mode (click to go dark) #}
                        <svg :class="{ 'hidden': isDark }" class="hidden w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg>
                    </button>

                    {# Palette selector #}
                    <div class="relative">
                        <button
                            type="button"
                            class="inline-flex items-center justify-center p-2 rounded-lg text-foreground/60 hover:text-accent hover:bg-surface-2/30 transition-all"
                            :aria-expanded="menuAriaExpanded"
                            aria-label="Select color palette"
                            @click="toggleMenu()"
                        >
                            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1.5" fill="currentColor" opacity="0.15"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5" fill="currentColor" opacity="0.15"/></svg>
                        </button>
                        <div
                            :class="{ 'hidden': !menuOpen }"
                            class="hidden absolute right-0 top-full mt-2 w-44 rounded-lg border border-border bg-background/95 backdrop-blur-md shadow-lg py-1.5"
                            role="listbox"
                            aria-label="Color palettes"
                        >
                            {% set palettes = [
                                ("default", "Default"),
                                ("ocean",   "Ocean"),
                                ("sunset",  "Sunset"),
                                ("rose",    "Rose"),
                                ("forest",  "Forest"),
                                ("mono",    "Mono"),
                            ] %}
                            {% for id, name in palettes %}
                            <button
                                type="button"
                                role="option"
                                class="palette-option w-full flex items-center gap-3 px-3 py-2 text-sm hover:bg-surface-2/50 transition-colors"
                                :class="{ 'text-accent font-medium': isActive('{{ id }}'), 'text-foreground/70': !isActive('{{ id }}') }"
                                :aria-selected="isActive('{{ id }}')"
                                @click="set('{{ id }}')"
                            >
                                <span class="palette-swatch palette-swatch-{{ id }} flex gap-0.5">
                                    <span class="w-3 h-3 rounded-full swatch-1"></span>
                                    <span class="w-3 h-3 rounded-full swatch-2"></span>
                                </span>
                                <span class="flex-1 text-left">{{ name }}</span>
                                <svg
                                    :class="{ 'hidden': !isActive('{{ id }}') }"
                                    class="hidden w-4 h-4"
                                    xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                                ><path d="M20 6 9 17l-5-5"/></svg>
                            </button>
                            {% endfor %}
                        </div>
                    </div>
                </li>
            </ul>
        </div>
    </div>
</nav>
