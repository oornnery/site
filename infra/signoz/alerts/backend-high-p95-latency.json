{
  "alert": "portfolio_backend_high_p95_latency",
  "ruleType": "promql_rule",
  "alertType": "METRIC_BASED_ALERT",
  "condition": {
    "thresholds": {
      "kind": "basic",
      "spec": [
        {
          "name": "warning",
          "target": 800,
          "matchType": "2",
          "op": "1",
          "channels": [
            "__REPLACE_WITH_SIGNOZ_CHANNEL__"
          ]
        }
      ]
    },
    "compositeQuery": {
      "queryType": "promql",
      "panelType": "graph",
      "queries": [
        {
          "type": "promql",
          "spec": {
            "name": "A",
            "query": "histogram_quantile(0.95, sum by (le) (rate({\"portfolio.http.request_duration_ms.bucket\"}[5m])))"
          }
        }
      ]
    },
    "selectedQueryName": "A"
  },
  "evaluation": {
    "kind": "rolling",
    "spec": {
      "evalWindow": "10m0s",
      "frequency": "30s"
    }
  },
  "labels": {
    "service": "portfolio-backend",
    "severity": "warning"
  },
  "annotations": {
    "summary": "Portfolio backend p95 latency above 800ms",
    "description": "HTTP p95 latency is {{$value}}ms, above the {{$threshold}}ms threshold for the portfolio backend."
  },
  "notificationSettings": {
    "groupBy": [
      "service",
      "severity"
    ],
    "usePolicy": false,
    "renotify": {
      "enabled": false,
      "interval": "30m",
      "alertStates": []
    }
  },
  "version": "v5",
  "schemaVersion": "v2alpha1"
}
