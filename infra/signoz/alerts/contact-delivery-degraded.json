{
  "alert": "portfolio_contact_delivery_degraded",
  "ruleType": "promql_rule",
  "alertType": "METRIC_BASED_ALERT",
  "condition": {
    "thresholds": {
      "kind": "basic",
      "spec": [
        {
          "name": "warning",
          "target": 20,
          "matchType": "2",
          "op": "1",
          "channels": [
            "__REPLACE_WITH_SIGNOZ_CHANNEL__"
          ]
        }
      ]
    },
    "compositeQuery": {
      "queryType": "promql",
      "panelType": "graph",
      "queries": [
        {
          "type": "promql",
          "spec": {
            "name": "A",
            "query": "sum(rate({\"portfolio.contact.submissions_total\",\"outcome\"=~\"notification_failed|success_partial\"}[10m])) / clamp_min(sum(rate({\"portfolio.contact.submissions_total\"}[10m])), 1) * 100"
          }
        }
      ]
    },
    "selectedQueryName": "A"
  },
  "evaluation": {
    "kind": "rolling",
    "spec": {
      "evalWindow": "10m0s",
      "frequency": "30s"
    }
  },
  "labels": {
    "service": "portfolio-backend",
    "severity": "warning"
  },
  "annotations": {
    "summary": "Portfolio contact delivery degradation detected",
    "description": "Contact submissions with degraded delivery reached {{$value}}%, above the {{$threshold}}% threshold."
  },
  "notificationSettings": {
    "groupBy": [
      "service",
      "severity"
    ],
    "usePolicy": false,
    "renotify": {
      "enabled": false,
      "interval": "30m",
      "alertStates": []
    }
  },
  "version": "v5",
  "schemaVersion": "v2alpha1"
}
